{
  "name": "@nizos/conduct",
  "version": "0.0.0",
  "description": "Process discipline for coding agents.",
  "license": "MIT",
  "author": "Nizar Selander",
  "repository": "github:nizos/conduct",
  "bugs": "https://github.com/nizos/conduct/issues",
  "homepage": "https://github.com/nizos/conduct#readme",
  "keywords": [
    "claude-code",
    "hooks",
    "agent",
    "policy",
    "guardrails"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "checks": "npm run lint:check && npm run format:check && npm run typecheck && npm test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tdd-guard-vitest": "^0.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
